# Copy this file to .env and fill in your values for local development.
# In production, set these as GitHub Secrets in your repository settings.

# Required: Notion internal integration token (starts with "ntn_")
# Create one at: https://www.notion.so/profile/integrations
NOTION_TOKEN=ntn_your_token_here

# Optional: Override default database IDs if you've cloned the Notion setup
# TASKS_DB_ID=83823c89bdca432fa824ed3bc5c7612d
# REVENUE_DB_ID=37315e4eaa5649ffb2fd7f6a8ad3d61f
